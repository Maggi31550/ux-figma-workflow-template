      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(cat:*)",
      "Bash(open:*)",
      "Bash(npx:*)",
      "Bash(/Users/socket9/Desktop/notebooklm-py/.venv/bin/notebooklm:*)",
