{
  "$metadata": {
    "tokenSetOrder": [
      "primitives/color",
      "primitives/spacing",
      "primitives/radius",
      "semantic/color.light",
      "semantic/color.dark",
      "semantic/spacing",
      "semantic/radius",
      "typography"
    ]
  },

  "primitives/color": {
    "white": { "$value": "#FFFFFF", "$type": "color" },
    "black": { "$value": "#000000", "$type": "color" },

    "slate": {
      "50":  { "$value": "#F8FAFC", "$type": "color" },
      "100": { "$value": "#F1F5F9", "$type": "color" },
      "200": { "$value": "#E2E8F0", "$type": "color" },
      "300": { "$value": "#CBD5E1", "$type": "color" },
      "400": { "$value": "#94A3B8", "$type": "color" },
      "500": { "$value": "#64748B", "$type": "color" },
      "600": { "$value": "#475569", "$type": "color" },
      "700": { "$value": "#334155", "$type": "color" },
      "800": { "$value": "#1E293B", "$type": "color" },
      "900": { "$value": "#0F172A", "$type": "color" },
      "950": { "$value": "#020617", "$type": "color" }
    },

    "blue": {
      "50":  { "$value": "#EFF6FF", "$type": "color" },
      "100": { "$value": "#DBEAFE", "$type": "color" },
      "200": { "$value": "#BFDBFE", "$type": "color" },
      "400": { "$value": "#60A5FA", "$type": "color" },
      "500": { "$value": "#3B82F6", "$type": "color" },
      "600": { "$value": "#2563EB", "$type": "color" },
      "700": { "$value": "#1D4ED8", "$type": "color" },
      "800": { "$value": "#1E40AF", "$type": "color" },
      "900": { "$value": "#1E3A8A", "$type": "color" }
    },

    "red": {
      "50":  { "$value": "#FEF2F2", "$type": "color" },
      "100": { "$value": "#FEE2E2", "$type": "color" },
      "400": { "$value": "#F87171", "$type": "color" },
      "500": { "$value": "#EF4444", "$type": "color" },
      "600": { "$value": "#DC2626", "$type": "color" },
      "700": { "$value": "#B91C1C", "$type": "color" }
    },

    "green": {
      "50":  { "$value": "#F0FDF4", "$type": "color" },
      "100": { "$value": "#DCFCE7", "$type": "color" },
      "400": { "$value": "#4ADE80", "$type": "color" },
      "500": { "$value": "#22C55E", "$type": "color" },
      "600": { "$value": "#16A34A", "$type": "color" },
      "700": { "$value": "#15803D", "$type": "color" }
    },

    "yellow": {
      "50":  { "$value": "#FEFCE8", "$type": "color" },
      "100": { "$value": "#FEF9C3", "$type": "color" },
      "400": { "$value": "#FACC15", "$type": "color" },
      "500": { "$value": "#EAB308", "$type": "color" },
      "600": { "$value": "#CA8A04", "$type": "color" }
    }
  },

  "primitives/spacing": {
    "0":  { "$value": 0,  "$type": "spacing" },
    "1":  { "$value": 4,  "$type": "spacing" },
    "2":  { "$value": 8,  "$type": "spacing" },
    "3":  { "$value": 12, "$type": "spacing" },
    "4":  { "$value": 16, "$type": "spacing" },
    "5":  { "$value": 20, "$type": "spacing" },
    "6":  { "$value": 24, "$type": "spacing" },
    "8":  { "$value": 32, "$type": "spacing" },
    "10": { "$value": 40, "$type": "spacing" },
    "12": { "$value": 48, "$type": "spacing" },
    "16": { "$value": 64, "$type": "spacing" },
    "20": { "$value": 80, "$type": "spacing" }
  },

  "primitives/radius": {
    "none": { "$value": 0,    "$type": "borderRadius" },
    "sm":   { "$value": 4,    "$type": "borderRadius" },
    "md":   { "$value": 8,    "$type": "borderRadius" },
    "lg":   { "$value": 12,   "$type": "borderRadius" },
    "xl":   { "$value": 16,   "$type": "borderRadius" },
    "2xl":  { "$value": 24,   "$type": "borderRadius" },
    "full": { "$value": 9999, "$type": "borderRadius" }
  },

  "semantic/color.light": {
    "color": {
      "bg": {
        "primary":   { "$value": "{primitives/color.white}",     "$type": "color" },
        "secondary": { "$value": "{primitives/color.slate.50}",  "$type": "color" },
        "tertiary":  { "$value": "{primitives/color.slate.100}", "$type": "color" },
        "overlay":   { "$value": "{primitives/color.slate.200}", "$type": "color" },
        "inverse":   { "$value": "{primitives/color.slate.900}", "$type": "color" }
      },
      "text": {
        "primary":   { "$value": "{primitives/color.slate.900}", "$type": "color" },
        "secondary": { "$value": "{primitives/color.slate.600}", "$type": "color" },
        "tertiary":  { "$value": "{primitives/color.slate.400}", "$type": "color" },
        "disabled":  { "$value": "{primitives/color.slate.300}", "$type": "color" },
        "inverse":   { "$value": "{primitives/color.white}",     "$type": "color" },
        "link":      { "$value": "{primitives/color.blue.600}",  "$type": "color" }
      },
      "border": {
        "default": { "$value": "{primitives/color.slate.200}", "$type": "color" },
        "strong":  { "$value": "{primitives/color.slate.400}", "$type": "color" },
        "focus":   { "$value": "{primitives/color.blue.500}",  "$type": "color" }
      },
      "action": {
        "primary":       { "$value": "{primitives/color.blue.600}",  "$type": "color" },
        "primary-hover": { "$value": "{primitives/color.blue.700}",  "$type": "color" },
        "primary-text":  { "$value": "{primitives/color.white}",     "$type": "color" },
        "danger":        { "$value": "{primitives/color.red.500}",   "$type": "color" },
        "danger-hover":  { "$value": "{primitives/color.red.600}",   "$type": "color" },
        "success":       { "$value": "{primitives/color.green.500}", "$type": "color" },
        "warning":       { "$value": "{primitives/color.yellow.500}","$type": "color" }
      },
      "surface": {
        "danger":  { "$value": "{primitives/color.red.50}",   "$type": "color" },
        "success": { "$value": "{primitives/color.green.50}", "$type": "color" },
        "warning": { "$value": "{primitives/color.yellow.50}","$type": "color" },
        "info":    { "$value": "{primitives/color.blue.50}",  "$type": "color" }
      }
    }
  },

  "semantic/color.dark": {
    "color": {
      "bg": {
        "primary":   { "$value": "{primitives/color.slate.950}", "$type": "color" },
        "secondary": { "$value": "{primitives/color.slate.900}", "$type": "color" },
        "tertiary":  { "$value": "{primitives/color.slate.800}", "$type": "color" },
        "overlay":   { "$value": "{primitives/color.slate.700}", "$type": "color" },
        "inverse":   { "$value": "{primitives/color.white}",     "$type": "color" }
      },
      "text": {
        "primary":   { "$value": "{primitives/color.white}",     "$type": "color" },
        "secondary": { "$value": "{primitives/color.slate.400}", "$type": "color" },
        "tertiary":  { "$value": "{primitives/color.slate.500}", "$type": "color" },
        "disabled":  { "$value": "{primitives/color.slate.600}", "$type": "color" },
        "inverse":   { "$value": "{primitives/color.slate.900}", "$type": "color" },
        "link":      { "$value": "{primitives/color.blue.400}",  "$type": "color" }
      },
      "border": {
        "default": { "$value": "{primitives/color.slate.700}", "$type": "color" },
        "strong":  { "$value": "{primitives/color.slate.500}", "$type": "color" },
        "focus":   { "$value": "{primitives/color.blue.400}",  "$type": "color" }
      },
      "action": {
        "primary":       { "$value": "{primitives/color.blue.500}",  "$type": "color" },
        "primary-hover": { "$value": "{primitives/color.blue.400}",  "$type": "color" },
        "primary-text":  { "$value": "{primitives/color.white}",     "$type": "color" },
        "danger":        { "$value": "{primitives/color.red.400}",   "$type": "color" },
        "danger-hover":  { "$value": "{primitives/color.red.300}",   "$type": "color" },
        "success":       { "$value": "{primitives/color.green.400}", "$type": "color" },
        "warning":       { "$value": "{primitives/color.yellow.400}","$type": "color" }
      },
      "surface": {
        "danger":  { "$value": "{primitives/color.red.700}",    "$type": "color" },
        "success": { "$value": "{primitives/color.green.700}",  "$type": "color" },
        "warning": { "$value": "{primitives/color.yellow.700}", "$type": "color" },
        "info":    { "$value": "{primitives/color.blue.800}",   "$type": "color" }
      }
    }
  },

  "semantic/spacing": {
    "spacing": {
      "xs":  { "$value": "{primitives/spacing.1}",  "$type": "spacing" },
      "sm":  { "$value": "{primitives/spacing.2}",  "$type": "spacing" },
      "md":  { "$value": "{primitives/spacing.4}",  "$type": "spacing" },
      "lg":  { "$value": "{primitives/spacing.6}",  "$type": "spacing" },
      "xl":  { "$value": "{primitives/spacing.8}",  "$type": "spacing" },
      "2xl": { "$value": "{primitives/spacing.12}", "$type": "spacing" },
      "3xl": { "$value": "{primitives/spacing.16}", "$type": "spacing" }
    }
  },

  "semantic/radius": {
    "radius": {
      "none": { "$value": "{primitives/radius.none}", "$type": "borderRadius" },
      "sm":   { "$value": "{primitives/radius.sm}",   "$type": "borderRadius" },
      "md":   { "$value": "{primitives/radius.md}",   "$type": "borderRadius" },
      "lg":   { "$value": "{primitives/radius.lg}",   "$type": "borderRadius" },
      "xl":   { "$value": "{primitives/radius.xl}",   "$type": "borderRadius" },
      "full": { "$value": "{primitives/radius.full}", "$type": "borderRadius" }
    }
  },

  "typography": {
    "font": {
      "family": {
        "sans": { "$value": "Inter, sans-serif",         "$type": "fontFamilies" },
        "mono": { "$value": "JetBrains Mono, monospace", "$type": "fontFamilies" }
      },
      "weight": {
        "regular":  { "$value": "400", "$type": "fontWeights" },
        "medium":   { "$value": "500", "$type": "fontWeights" },
        "semibold": { "$value": "600", "$type": "fontWeights" },
        "bold":     { "$value": "700", "$type": "fontWeights" }
      }
    },

    "display": {
      "xl": {
        "$value": {
          "fontFamily": "Inter, sans-serif",
          "fontWeight": "700",
          "fontSize": "40",
          "lineHeight": "1.15",
          "letterSpacing": "-1.5px"
